# AI Log Error Detector — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── OpenAI (required when llm.provider = "openai") ─────────
OPENAI_API_KEY=sk-...

# ── Azure OpenAI (alternative to standard OpenAI) ──────────
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── Microsoft Teams Incoming Webhook ───────────────────────
# Create via: Teams channel → Connectors → Incoming Webhook
# Or via Power Automate / Workflows
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ── Optional overrides (config.yaml takes precedence unless set) ──
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LOG_LEVEL=INFO
